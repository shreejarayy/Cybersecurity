# Argus ASM — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ------------------------------------------------------------------ #
# Database (required)
# ------------------------------------------------------------------ #
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:password@localhost:5432/argus

# Set to true to print all SQL queries to the console (dev only)
DB_ECHO=false

# ------------------------------------------------------------------ #
# Scan tuning (optional — defaults are fine to start)
# ------------------------------------------------------------------ #
PORT_SCAN_TIMEOUT=1.0
PORT_SCAN_WORKERS=150
SUBDOMAIN_WORKERS=20
BANNER_TIMEOUT=3.0

# ------------------------------------------------------------------ #
# API keys (optional — leave blank to skip those modules)
# ------------------------------------------------------------------ #
SHODAN_API_KEY=
NVD_API_KEY=

# ------------------------------------------------------------------ #
# Scheduler (used in Week 2)
# ------------------------------------------------------------------ #
SCAN_INTERVAL_HOURS=24
